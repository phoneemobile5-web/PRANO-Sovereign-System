{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "بيانات ملاح الأرض في عمارة Gemma Core 2030",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "lastLogin": { "type": "number" },
        "avatar": { "type": "string" },
        "mission": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "CustomPrompt": {
      "title": "Custom Prompt",
      "description": "تعليمات النظام (الچينيوم الوراثي للمهام)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "prompt": { "type": "string" },
        "model": { "type": "string" },
        "apiKeys": { "type": "array", "items": { "type": "string" } },
        "isSustainable": { "type": "boolean" }
      },
      "required": ["name", "prompt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "إخراج إدراكي سينابتي فردي",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "timestamp": { "type": "number" }
      },
      "required": ["text", "role", "timestamp"]
    },
    "ChatHistory": {
      "title": "Chat History",
      "description": "سجل الاستدلال السينابتي المتكامل للملاح",
      "type": "object",
      "properties": {
        "messages": { 
          "type": "array", 
          "items": { "$ref": "#/backend/entities/ChatMessage" } 
        },
        "lastUpdated": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "قاعدة بيانات ملاحي الأرض"
    },
    "/customPrompts/{userId}": {
      "schema": "CustomPrompt",
      "description": "مستودع الچينيوم الوراثي للمهام"
    },
    "/chatHistories/{userId}": {
      "schema": "ChatHistory",
      "description": "أرشيف الاستدلال السينابتي"
    }
  }
}