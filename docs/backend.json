
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "بيانات ملاح الأرض الأساسية",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "lastLogin": { "type": "number" },
        "avatar": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "CustomPrompt": {
      "title": "Custom Prompt",
      "description": "الأوامر المخصصة (الچينيوم الوراثي)",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "prompt": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["label", "prompt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "عنصر إخراج إدراكي منفرد",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "feedback": { "type": "string", "enum": ["up", "down", "none"] },
        "timestamp": { "type": "number" }
      },
      "required": ["text", "role", "timestamp"]
    },
    "ChatHistory": {
      "title": "Chat History",
      "description": "سجل الربط السينابتي المتكامل",
      "type": "object",
      "properties": {
        "messages": { 
          "type": "array", 
          "items": { "$ref": "#/backend/entities/ChatMessage" } 
        },
        "lastUpdated": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "بيانات المستخدمين الأساسية"
    },
    "/customPrompts/{userId}": {
      "schema": "CustomPrompt",
      "description": "مجموعة الأوامر المخصصة لملاح الأرض"
    },
    "/chatHistories/{userId}": {
      "schema": "ChatHistory",
      "description": "سجلات الدردشة والاستدلال السينابتي"
    }
  }
}
